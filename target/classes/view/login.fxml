            <Circle fill="#27AE60" layoutX="84.0" layoutY="34.0" radius="20.0" stroke="BLACK" strokeType="INSIDE" />
            <Circle fill="#E74C3C" layoutX="135.0" layoutY="34.0" radius="20.0" stroke="BLACK" strokeType="INSIDE" />
