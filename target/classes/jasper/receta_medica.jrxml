<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="receta_medica" language="java" pageWidth="420" pageHeight="595"
              columnWidth="380" leftMargin="20" rightMargin="20"
              topMargin="20" bottomMargin="20">

    <parameter name="emisorNombre"   class="java.lang.String"/>
    <parameter name="emisorRuc"      class="java.lang.String"/>
    <parameter name="emisorDireccion" class="java.lang.String"/>
    <parameter name="paciente"       class="java.lang.String"/>
    <parameter name="dni"            class="java.lang.String"/>
    <parameter name="medico"         class="java.lang.String"/>
    <parameter name="numColegiatura" class="java.lang.String"/>
    <parameter name="especialidad"   class="java.lang.String"/>
    <parameter name="diagnostico"    class="java.lang.String"/>
    <parameter name="indicaciones"   class="java.lang.String"/>
    <parameter name="recomendaciones" class="java.lang.String"/>
    <parameter name="fecha"          class="java.lang.String"/>

    <field name="medicamento" class="java.lang.String"/>
    <field name="dosis"       class="java.lang.String"/>
    <field name="frecuencia"  class="java.lang.String"/>
    <field name="duracion"    class="java.lang.String"/>
    <field name="via"         class="java.lang.String"/>

    <title>
        <band height="120" splitType="Stretch">
            <textField>
                <reportElement x="0" y="0" width="380" height="22"/>
                <textElement textAlignment="Center"><font size="14" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$P{emisorNombre} == null ? "Clínica Más Cerca de Dios" : $P{emisorNombre}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="22" width="380" height="14"/>
                <textElement textAlignment="Center"><font size="9"/></textElement>
                <textFieldExpression><![CDATA["RUC: " + ($P{emisorRuc} == null ? "" : $P{emisorRuc})]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="36" width="380" height="14"/>
                <textElement textAlignment="Center"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{emisorDireccion} == null ? "" : $P{emisorDireccion}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="0" y="56" width="380" height="20"/>
                <textElement textAlignment="Center"><font size="13" isBold="true"/></textElement>
                <text><![CDATA[RECETA MÉDICA]]></text>
            </staticText>
            <line>
                <reportElement x="0" y="78" width="380" height="1"/>
            </line>
            <textField>
                <reportElement x="0" y="84" width="280" height="14"/>
                <textElement><font size="10"/></textElement>
                <textFieldExpression><![CDATA["Paciente: " + ($P{paciente} == null ? "" : $P{paciente}) + "  ·  DNI: " + ($P{dni} == null ? "" : $P{dni})]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="280" y="84" width="100" height="14"/>
                <textElement textAlignment="Right"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{fecha} == null ? "" : $P{fecha}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="100" width="380" height="14"/>
                <textElement><font size="10"/></textElement>
                <textFieldExpression><![CDATA["Diagnóstico: " + ($P{diagnostico} == null ? "—" : $P{diagnostico})]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="22" splitType="Stretch">
            <staticText>
                <reportElement x="0" y="0" width="380" height="1"/>
                <textElement/><text><![CDATA[]]></text>
            </staticText>
            <line>
                <reportElement x="0" y="0" width="380" height="1"/>
            </line>
            <staticText>
                <reportElement x="0" y="4" width="150" height="16"/>
                <textElement><font size="10" isBold="true"/></textElement>
                <text><![CDATA[Medicamento]]></text>
            </staticText>
            <staticText>
                <reportElement x="150" y="4" width="60" height="16"/>
                <textElement><font size="10" isBold="true"/></textElement>
                <text><![CDATA[Dosis]]></text>
            </staticText>
            <staticText>
                <reportElement x="210" y="4" width="80" height="16"/>
                <textElement><font size="10" isBold="true"/></textElement>
                <text><![CDATA[Frecuencia]]></text>
            </staticText>
            <staticText>
                <reportElement x="290" y="4" width="60" height="16"/>
                <textElement><font size="10" isBold="true"/></textElement>
                <text><![CDATA[Duración]]></text>
            </staticText>
            <staticText>
                <reportElement x="350" y="4" width="30" height="16"/>
                <textElement><font size="10" isBold="true"/></textElement>
                <text><![CDATA[Vía]]></text>
            </staticText>
            <line>
                <reportElement x="0" y="20" width="380" height="1"/>
            </line>
        </band>
    </columnHeader>

    <detail>
        <band height="18" splitType="Stretch">
            <textField isStretchWithOverflow="true">
                <reportElement x="0" y="2" width="150" height="14"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{medicamento}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="150" y="2" width="60" height="14"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{dosis}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="210" y="2" width="80" height="14"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{frecuencia}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="290" y="2" width="60" height="14"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{duracion}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="350" y="2" width="30" height="14"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{via}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <summary>
        <band height="160" splitType="Stretch">
            <line>
                <reportElement x="0" y="0" width="380" height="1"/>
            </line>
            <staticText>
                <reportElement x="0" y="6" width="120" height="14"/>
                <textElement><font size="10" isBold="true"/></textElement>
                <text><![CDATA[Indicaciones:]]></text>
            </staticText>
            <textField isStretchWithOverflow="true">
                <reportElement x="0" y="20" width="380" height="30"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{indicaciones} == null ? "—" : $P{indicaciones}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="0" y="56" width="160" height="14"/>
                <textElement><font size="10" isBold="true"/></textElement>
                <text><![CDATA[Recomendaciones:]]></text>
            </staticText>
            <textField isStretchWithOverflow="true">
                <reportElement x="0" y="70" width="380" height="30"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{recomendaciones} == null ? "—" : $P{recomendaciones}]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="220" y="118" width="160" height="1"/>
            </line>
            <textField>
                <reportElement x="220" y="120" width="160" height="14"/>
                <textElement textAlignment="Center"><font size="9" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$P{medico} == null ? "" : $P{medico}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="220" y="134" width="160" height="12"/>
                <textElement textAlignment="Center"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[($P{especialidad} == null ? "" : $P{especialidad}) + " · " + ($P{numColegiatura} == null ? "" : "CMP " + $P{numColegiatura})]]></textFieldExpression>
            </textField>
        </band>
    </summary>
</jasperReport>
