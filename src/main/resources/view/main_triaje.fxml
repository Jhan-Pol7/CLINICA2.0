<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="780.0" prefWidth="980.0" spacing="12.0"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="pe.edu.upeu.clinica.controller.MainTriajeController">
   <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/></padding>
   <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Triaje (signos vitales)"/>
   <HBox spacing="10.0">
      <Label text="Cola de pacientes EN_ESPERA:" style="-fx-font-weight: bold;"/>
      <Button onAction="#onRecargar" text="Recargar"/>
   </HBox>
   <TableView fx:id="tabla" prefHeight="220.0"/>

   <Label fx:id="lblPaciente" style="-fx-font-size: 14px; -fx-text-fill: #2980b9;" text="Selecciona una cita →"/>

   <TitledPane animated="false" collapsible="false" text="Signos vitales">
      <content>
         <GridPane hgap="10.0" vgap="8.0">
            <columnConstraints>
               <ColumnConstraints hgrow="NEVER"  minWidth="140.0"/>
               <ColumnConstraints hgrow="ALWAYS" minWidth="120.0"/>
               <ColumnConstraints hgrow="NEVER"  minWidth="140.0"/>
               <ColumnConstraints hgrow="ALWAYS" minWidth="120.0"/>
            </columnConstraints>
            <rowConstraints>
               <RowConstraints/>
               <RowConstraints/>
               <RowConstraints/>
               <RowConstraints/>
               <RowConstraints/>
            </rowConstraints>
            <padding><Insets bottom="10.0" left="14.0" right="14.0" top="10.0"/></padding>

            <Label text="Presión sistólica (mmHg):"  GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="txtSistolica"          GridPane.rowIndex="0" GridPane.columnIndex="1"/>
            <Label text="Presión diastólica (mmHg):" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
            <TextField fx:id="txtDiastolica"         GridPane.rowIndex="0" GridPane.columnIndex="3"/>

            <Label text="Temperatura (°C):"  GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="txtTemperatura" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
            <Label text="Frec. cardíaca (lpm):" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
            <TextField fx:id="txtFrecCard"   GridPane.rowIndex="1" GridPane.columnIndex="3"/>

            <Label text="Peso (kg):"  GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <TextField fx:id="txtPeso" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            <Label text="Talla (m):"  GridPane.rowIndex="2" GridPane.columnIndex="2"/>
            <TextField fx:id="txtTalla" GridPane.rowIndex="2" GridPane.columnIndex="3"/>

            <Label text="Motivo de consulta:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <TextArea fx:id="txtMotivo" prefRowCount="2" wrapText="true"
                      GridPane.rowIndex="3" GridPane.columnIndex="1" GridPane.columnSpan="3"/>

            <Label text="Observaciones:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
            <TextArea fx:id="txtObservaciones" prefRowCount="2" wrapText="true"
                      GridPane.rowIndex="4" GridPane.columnIndex="1" GridPane.columnSpan="3"/>
         </GridPane>
      </content>
   </TitledPane>

   <HBox spacing="8.0">
      <Button onAction="#onGuardarTriaje" style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-font-weight: bold;" text="Guardar Triaje"/>
      <Button onAction="#onLimpiar" text="Limpiar"/>
   </HBox>
</VBox>
