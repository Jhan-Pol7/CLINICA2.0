<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="500.0" prefWidth="700.0" spacing="14.0"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="pe.edu.upeu.clinica.controller.MainReporteController">
   <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/></padding>
   <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Reporte de Citas (Jasper)"/>
   <Label text="Todos los filtros son opcionales. Deja un campo vacío para no filtrar por él."/>

   <TitledPane animated="false" collapsible="false" text="Filtros">
      <content>
         <GridPane hgap="10.0" vgap="10.0">
            <columnConstraints>
               <ColumnConstraints hgrow="NEVER"  minWidth="110.0"/>
               <ColumnConstraints hgrow="ALWAYS" minWidth="200.0"/>
               <ColumnConstraints hgrow="NEVER"  minWidth="110.0"/>
               <ColumnConstraints hgrow="ALWAYS" minWidth="200.0"/>
            </columnConstraints>
            <rowConstraints>
               <RowConstraints/>
               <RowConstraints/>
               <RowConstraints/>
            </rowConstraints>
            <padding><Insets bottom="14.0" left="14.0" right="14.0" top="14.0"/></padding>

            <Label text="Fecha desde:"   GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <DatePicker fx:id="dpFechaIni" maxWidth="1.7976931348623157E308"
                        GridPane.rowIndex="0" GridPane.columnIndex="1"/>
            <Label text="Fecha hasta:"   GridPane.rowIndex="0" GridPane.columnIndex="2"/>
            <DatePicker fx:id="dpFechaFin" maxWidth="1.7976931348623157E308"
                        GridPane.rowIndex="0" GridPane.columnIndex="3"/>

            <Label text="Especialidad:"  GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <ComboBox fx:id="cmbEspecialidad" maxWidth="1.7976931348623157E308"
                      GridPane.rowIndex="1" GridPane.columnIndex="1"/>
            <Label text="Médico:"        GridPane.rowIndex="1" GridPane.columnIndex="2"/>
            <ComboBox fx:id="cmbMedico"   maxWidth="1.7976931348623157E308"
                      GridPane.rowIndex="1" GridPane.columnIndex="3"/>

            <Label text="Estado:"        GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <ComboBox fx:id="cmbEstado"   maxWidth="1.7976931348623157E308"
                      GridPane.rowIndex="2" GridPane.columnIndex="1"/>
         </GridPane>
      </content>
   </TitledPane>

   <HBox spacing="8.0">
      <Button onAction="#onGenerar"     style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-font-weight: bold;" text="Generar (visor)"/>
      <Button onAction="#onExportarPdf" text="Exportar PDF"/>
      <Button onAction="#onLimpiar"     text="Limpiar filtros"/>
   </HBox>
</VBox>
