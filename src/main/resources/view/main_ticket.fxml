<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="640.0" prefWidth="640.0" spacing="10.0"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="pe.edu.upeu.clinica.controller.MainTicketController">
   <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/></padding>
   <Label fx:id="lblTitulo" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Ticket de cita"/>
   <TextArea fx:id="txtTicket" editable="false" prefHeight="460.0" wrapText="false"/>
   <HBox spacing="8.0">
      <Button onAction="#onRecargar"     text="Recargar"/>
      <Button onAction="#onCopiar"       text="Copiar"/>
      <Button onAction="#onGuardarTxt"   text="Guardar .txt"/>
      <Button onAction="#onVisorJasper"  style="-fx-background-color: #2980B9; -fx-text-fill: white; -fx-font-weight: bold;" text="Visor Jasper"/>
      <Button onAction="#onExportarPdf"  text="Exportar PDF"/>
      <Button onAction="#onImprimir"     text="Imprimir (ESC/POS)"/>
   </HBox>
</VBox>
