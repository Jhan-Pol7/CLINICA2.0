<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="780.0" prefWidth="980.0" spacing="10.0"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="pe.edu.upeu.clinica.controller.MainCitaController">
   <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/></padding>
   <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Registrar Cita Médica"/>
   <Label fx:id="lblStatus" style="-fx-text-fill: #2980b9;" text=""/>

   <TitledPane animated="false" collapsible="false" text="1) Paciente">
      <content>
         <GridPane hgap="10.0" vgap="8.0">
            <columnConstraints>
               <ColumnConstraints hgrow="NEVER"  minWidth="80.0"/>
               <ColumnConstraints hgrow="ALWAYS" minWidth="180.0"/>
               <ColumnConstraints hgrow="NEVER"  minWidth="80.0"/>
               <ColumnConstraints hgrow="ALWAYS" minWidth="180.0"/>
            </columnConstraints>
            <rowConstraints>
               <RowConstraints/>
               <RowConstraints/>
            </rowConstraints>
            <padding><Insets bottom="10.0" left="14.0" right="14.0" top="10.0"/></padding>

            <Label text="DNI:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <HBox spacing="6.0" GridPane.rowIndex="0" GridPane.columnIndex="1">
               <TextField fx:id="txtDni" HBox.hgrow="ALWAYS"/>
               <Button onAction="#onBuscarPaciente" text="Buscar"/>
            </HBox>
            <Label text="Teléfono:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
            <TextField fx:id="txtTelefono" editable="false" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

            <Label text="Nombres:"   GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="txtNombres"   editable="false" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
            <Label text="Apellidos:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
            <TextField fx:id="txtApellidos" editable="false" GridPane.rowIndex="1" GridPane.columnIndex="3"/>
         </GridPane>
      </content>
   </TitledPane>

   <TitledPane animated="false" collapsible="false" text="2) Cita">
      <content>
         <GridPane hgap="10.0" vgap="8.0">
            <columnConstraints>
               <ColumnConstraints hgrow="NEVER"  minWidth="100.0"/>
               <ColumnConstraints hgrow="ALWAYS" minWidth="160.0"/>
               <ColumnConstraints hgrow="NEVER"  minWidth="100.0"/>
               <ColumnConstraints hgrow="ALWAYS" minWidth="160.0"/>
            </columnConstraints>
            <rowConstraints>
               <RowConstraints/>
               <RowConstraints/>
               <RowConstraints/>
            </rowConstraints>
            <padding><Insets bottom="10.0" left="14.0" right="14.0" top="10.0"/></padding>

            <Label text="Especialidad:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <ComboBox fx:id="cmbEspecialidad" maxWidth="1.7976931348623157E308"
                      GridPane.rowIndex="0" GridPane.columnIndex="1"/>
            <Label text="Médico:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
            <ComboBox fx:id="cmbMedico" maxWidth="1.7976931348623157E308"
                      GridPane.rowIndex="0" GridPane.columnIndex="3"/>

            <Label text="Fecha:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <DatePicker fx:id="dpFecha" maxWidth="1.7976931348623157E308"
                        GridPane.rowIndex="1" GridPane.columnIndex="1"/>
            <Label text="Hora:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
            <HBox spacing="4.0" alignment="CENTER_LEFT" GridPane.rowIndex="1" GridPane.columnIndex="3">
               <Spinner fx:id="spnHoraH" prefWidth="70.0" editable="true"/>
               <Label text=":" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
               <Spinner fx:id="spnHoraM" prefWidth="70.0" editable="true"/>
            </HBox>

            <Label text="Tipo:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <ComboBox fx:id="cmbTipo" maxWidth="1.7976931348623157E308"
                      GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            <Label text="Motivo:" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
            <TextArea fx:id="txtMotivo" prefRowCount="2" wrapText="true"
                      GridPane.rowIndex="2" GridPane.columnIndex="3"/>
         </GridPane>
      </content>
   </TitledPane>

   <HBox spacing="8.0">
      <Button onAction="#onRegistrarCita" style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-font-weight: bold;" text="Registrar Cita"/>
      <Button onAction="#onLimpiar"  text="Limpiar"/>
      <Button onAction="#onRecargar" text="Recargar"/>
   </HBox>

   <Label style="-fx-font-weight: bold;" text="Citas del día seleccionado (click Editar = ver ticket; Eliminar = cancelar):"/>
   <TableView fx:id="tabla" prefHeight="280.0"/>
</VBox>
