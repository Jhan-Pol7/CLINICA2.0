<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="980.0" prefWidth="980.0" spacing="10.0"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="pe.edu.upeu.clinica.controller.MainConsultaController">
   <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/></padding>
   <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Consulta Médica"/>
   <HBox spacing="10.0">
      <Label text="Citas EN_CONSULTA asignadas al médico:"/>
      <Button onAction="#onRecargar" text="Recargar"/>
   </HBox>
   <TableView fx:id="tabla" prefHeight="180.0"/>

   <Label fx:id="lblPaciente" style="-fx-font-size: 14px; -fx-text-fill: #2980b9;" text="Selecciona una cita →"/>
   <Label fx:id="lblSignosVitales" style="-fx-font-size: 12px; -fx-text-fill: #555;" text=""/>

   <TitledPane animated="false" collapsible="false" text="Anamnesis y diagnóstico">
      <content>
         <GridPane hgap="10.0" vgap="6.0">
            <columnConstraints>
               <ColumnConstraints hgrow="NEVER"  minWidth="140.0"/>
               <ColumnConstraints hgrow="ALWAYS" minWidth="260.0"/>
               <ColumnConstraints hgrow="NEVER"  minWidth="140.0"/>
               <ColumnConstraints hgrow="ALWAYS" minWidth="260.0"/>
            </columnConstraints>
            <rowConstraints>
               <RowConstraints/>
               <RowConstraints/>
            </rowConstraints>
            <padding><Insets bottom="10.0" left="14.0" right="14.0" top="10.0"/></padding>

            <Label text="Síntomas:"     GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextArea fx:id="txtSintomas"     prefRowCount="2" wrapText="true"
                      GridPane.rowIndex="0" GridPane.columnIndex="1"/>
            <Label text="Diagnóstico*:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
            <TextArea fx:id="txtDiagnostico"  prefRowCount="2" wrapText="true"
                      GridPane.rowIndex="0" GridPane.columnIndex="3"/>

            <Label text="Exámenes solicitados:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextArea fx:id="txtExamenes"     prefRowCount="2" wrapText="true"
                      GridPane.rowIndex="1" GridPane.columnIndex="1"/>
            <Label text="Observaciones:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
            <TextArea fx:id="txtObservaciones" prefRowCount="2" wrapText="true"
                      GridPane.rowIndex="1" GridPane.columnIndex="3"/>
         </GridPane>
      </content>
   </TitledPane>

   <TitledPane animated="false" collapsible="false" text="Receta médica (opcional)">
      <content>
         <VBox spacing="8.0">
            <padding><Insets bottom="10.0" left="14.0" right="14.0" top="10.0"/></padding>
            <GridPane hgap="6.0" vgap="6.0">
               <columnConstraints>
                  <ColumnConstraints hgrow="ALWAYS" minWidth="160.0"/>
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="90.0"/>
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="120.0"/>
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="100.0"/>
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="80.0"/>
                  <ColumnConstraints hgrow="NEVER" minWidth="180.0"/>
               </columnConstraints>
               <rowConstraints>
                  <RowConstraints/>
                  <RowConstraints/>
               </rowConstraints>
               <Label text="Medicamento" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
               <Label text="Dosis"       GridPane.rowIndex="0" GridPane.columnIndex="1"/>
               <Label text="Frecuencia"  GridPane.rowIndex="0" GridPane.columnIndex="2"/>
               <Label text="Duración"    GridPane.rowIndex="0" GridPane.columnIndex="3"/>
               <Label text="Vía"         GridPane.rowIndex="0" GridPane.columnIndex="4"/>

               <TextField fx:id="txtMed"   promptText="Paracetamol 500mg" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
               <TextField fx:id="txtDosis" promptText="1 tab"             GridPane.rowIndex="1" GridPane.columnIndex="1"/>
               <TextField fx:id="txtFrec"  promptText="c/8 hrs"           GridPane.rowIndex="1" GridPane.columnIndex="2"/>
               <TextField fx:id="txtDur"   promptText="5 días"            GridPane.rowIndex="1" GridPane.columnIndex="3"/>
               <TextField fx:id="txtVia"   promptText="VO"                GridPane.rowIndex="1" GridPane.columnIndex="4"/>
               <HBox spacing="6.0" GridPane.rowIndex="1" GridPane.columnIndex="5">
                  <Button onAction="#onAgregarMedicamento" style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-font-weight: bold;"  text="+ Agregar"/>
                  <Button onAction="#onQuitarMedicamento"  style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-font-weight: bold;" text="− Quitar"/>
               </HBox>
            </GridPane>
            <TableView fx:id="tablaDetalles" prefHeight="150.0"/>
            <GridPane hgap="10.0" vgap="6.0">
               <columnConstraints>
                  <ColumnConstraints hgrow="NEVER"  minWidth="140.0"/>
                  <ColumnConstraints hgrow="ALWAYS" minWidth="280.0"/>
                  <ColumnConstraints hgrow="NEVER"  minWidth="140.0"/>
                  <ColumnConstraints hgrow="ALWAYS" minWidth="280.0"/>
               </columnConstraints>
               <rowConstraints>
                  <RowConstraints/>
               </rowConstraints>
               <Label text="Indicaciones generales:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
               <TextArea fx:id="txtIndicaciones" prefRowCount="2" wrapText="true"
                         GridPane.rowIndex="0" GridPane.columnIndex="1"/>
               <Label text="Recomendaciones:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
               <TextArea fx:id="txtRecomendaciones" prefRowCount="2" wrapText="true"
                         GridPane.rowIndex="0" GridPane.columnIndex="3"/>
            </GridPane>
         </VBox>
      </content>
   </TitledPane>

   <HBox spacing="8.0">
      <Button onAction="#onFinalizarConsulta" style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-font-weight: bold;" text="Finalizar Consulta"/>
      <Button onAction="#onLimpiar" text="Limpiar"/>
   </HBox>
</VBox>
