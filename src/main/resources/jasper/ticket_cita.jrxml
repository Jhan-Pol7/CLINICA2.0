<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="ticket_cita" language="java" pageWidth="226" pageHeight="595"
              columnWidth="200" leftMargin="13" rightMargin="13"
              topMargin="10" bottomMargin="10" whenNoDataType="AllSectionsNoDetail">

    <parameter name="emisorNombre"   class="java.lang.String"/>
    <parameter name="emisorRuc"      class="java.lang.String"/>
    <parameter name="emisorDireccion" class="java.lang.String"/>
    <parameter name="numTicket"      class="java.lang.String"/>
    <parameter name="paciente"       class="java.lang.String"/>
    <parameter name="dni"            class="java.lang.String"/>
    <parameter name="especialidad"   class="java.lang.String"/>
    <parameter name="medico"         class="java.lang.String"/>
    <parameter name="fecha"          class="java.lang.String"/>
    <parameter name="hora"           class="java.lang.String"/>
    <parameter name="turno"          class="java.lang.String"/>
    <parameter name="tipoAtencion"   class="java.lang.String"/>

    <title>
        <band height="280" splitType="Stretch">
            <staticText>
                <reportElement x="0" y="0" width="200" height="14"/>
                <textElement textAlignment="Center"><font fontName="Monospaced" size="9"/></textElement>
                <text><![CDATA[========================================]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="14" width="200" height="16"/>
                <textElement textAlignment="Center"><font fontName="Monospaced" size="11" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$P{emisorNombre} == null ? "CLÍNICA MÁS CERCA DE DIOS" : $P{emisorNombre}.toUpperCase()]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="30" width="200" height="12"/>
                <textElement textAlignment="Center"><font fontName="Monospaced" size="8"/></textElement>
                <textFieldExpression><![CDATA["RUC: " + ($P{emisorRuc} == null ? "" : $P{emisorRuc})]]></textFieldExpression>
            </textField>
            <textField isStretchWithOverflow="true">
                <reportElement x="0" y="42" width="200" height="22"/>
                <textElement textAlignment="Center"><font fontName="Monospaced" size="8"/></textElement>
                <textFieldExpression><![CDATA[$P{emisorDireccion} == null ? "" : $P{emisorDireccion}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="0" y="64" width="200" height="12"/>
                <textElement textAlignment="Center"><font fontName="Monospaced" size="8"/></textElement>
                <text><![CDATA[----------------------------------------]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="76" width="200" height="14"/>
                <textElement textAlignment="Center"><font fontName="Monospaced" size="10" isBold="true"/></textElement>
                <text><![CDATA[TICKET DE CITA MÉDICA]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="90" width="200" height="12"/>
                <textElement textAlignment="Center"><font fontName="Monospaced" size="8"/></textElement>
                <text><![CDATA[----------------------------------------]]></text>
            </staticText>

            <textField>
                <reportElement x="0" y="104" width="200" height="12"/>
                <textElement><font fontName="Monospaced" size="9"/></textElement>
                <textFieldExpression><![CDATA["N° Ticket   : " + ($P{numTicket} == null ? "" : $P{numTicket})]]></textFieldExpression>
            </textField>
            <textField isStretchWithOverflow="true">
                <reportElement x="0" y="116" width="200" height="12"/>
                <textElement><font fontName="Monospaced" size="9"/></textElement>
                <textFieldExpression><![CDATA["Paciente    : " + ($P{paciente} == null ? "" : $P{paciente})]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="128" width="200" height="12"/>
                <textElement><font fontName="Monospaced" size="9"/></textElement>
                <textFieldExpression><![CDATA["DNI         : " + ($P{dni} == null ? "" : $P{dni})]]></textFieldExpression>
            </textField>
            <textField isStretchWithOverflow="true">
                <reportElement x="0" y="140" width="200" height="12"/>
                <textElement><font fontName="Monospaced" size="9"/></textElement>
                <textFieldExpression><![CDATA["Especialidad: " + ($P{especialidad} == null ? "" : $P{especialidad})]]></textFieldExpression>
            </textField>
            <textField isStretchWithOverflow="true">
                <reportElement x="0" y="152" width="200" height="12"/>
                <textElement><font fontName="Monospaced" size="9"/></textElement>
                <textFieldExpression><![CDATA["Médico      : " + ($P{medico} == null ? "" : $P{medico})]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="164" width="200" height="12"/>
                <textElement><font fontName="Monospaced" size="9"/></textElement>
                <textFieldExpression><![CDATA["Fecha       : " + ($P{fecha} == null ? "" : $P{fecha})]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="176" width="200" height="12"/>
                <textElement><font fontName="Monospaced" size="9"/></textElement>
                <textFieldExpression><![CDATA["Hora        : " + ($P{hora} == null ? "" : $P{hora})]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="188" width="200" height="12"/>
                <textElement><font fontName="Monospaced" size="9"/></textElement>
                <textFieldExpression><![CDATA["Turno       : N° " + ($P{turno} == null ? "?" : $P{turno})]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="200" width="200" height="12"/>
                <textElement><font fontName="Monospaced" size="9"/></textElement>
                <textFieldExpression><![CDATA["Tipo Atenc. : " + ($P{tipoAtencion} == null ? "" : $P{tipoAtencion})]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="216" width="200" height="12"/>
                <textElement textAlignment="Center"><font fontName="Monospaced" size="8"/></textElement>
                <text><![CDATA[----------------------------------------]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="228" width="200" height="12"/>
                <textElement textAlignment="Center"><font fontName="Monospaced" size="9"/></textElement>
                <text><![CDATA[Gracias por su preferencia]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="240" width="200" height="12"/>
                <textElement textAlignment="Center"><font fontName="Monospaced" size="9"/></textElement>
                <text><![CDATA[Conserve este ticket]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="254" width="200" height="14"/>
                <textElement textAlignment="Center"><font fontName="Monospaced" size="9"/></textElement>
                <text><![CDATA[========================================]]></text>
            </staticText>
        </band>
    </title>
</jasperReport>
